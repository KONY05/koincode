# Server runs locally on this port (auto-spawned by the CLI)
API_URL=http://localhost:37420

# SQLite DB path — defaults to ~/.koincode/data.db
# Override only for dev/testing (e.g. DATABASE_URL=file:/tmp/koincode-dev.db)
DATABASE_URL=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_KEY=

# Build-time — baked into the CLI binary via --define
MIXPANEL_TOKEN=
