    "@ai-sdk/openai": "^3.0.52",
    "@hono/zod-validator": "^0.7.6",
    "@koincode/database": "workspace:*",
    "@koincode/shared": "workspace:*",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.154",
    "dotenv": "^17.4.1",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  }
}
